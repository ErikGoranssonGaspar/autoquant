{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": {
      "*": "allow",
      "prepare.py": "deny",
      "~/.cache/autoquant/**": "deny",
    },
    "edit": {
      "*": "deny",
      "trade.py": "allow",
      "train.py": "allow",
      "results.tsv": "allow",
    },
    "bash": {
      "*": "allow",
      "uv add *": "deny",
      "uv pip *": "deny",
      "pip *": "deny"
    }
  }
}
